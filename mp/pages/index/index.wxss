.container {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: center;
  background-color: #ffffff;
  padding: 80rpx 40rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.header {
  text-align: center;
  margin-top: 60rpx;
  width: 100%;
}

.title {
  font-size: 44rpx;
  font-weight: 800;
  color: #1e3a8a;
  letter-spacing: 2rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #64748b;
  margin-bottom: 40rpx;
}

.role-selector {
  display: flex;
  flex-direction: column;
  width: 100%;
  padding: 40rpx 0;
  gap: 36rpx;
}

.role-btn {
  background-color: #f8fafc;
  color: #0f172a;
  border: 2rpx solid #e2e8f0;
  border-radius: 24rpx;
  height: 120rpx;
  line-height: 120rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  transition: all 0.2s ease;
  box-shadow: 0 4rpx 6rpx rgba(0, 0, 0, 0.02);
}

.role-btn-hover {
  background-color: #e0f2fe; /* 淡蓝色激活状态 */
  border-color: #bae6fd;
  color: #0369a1;
  transform: scale(0.98);
}

.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  margin-bottom: 40rpx;
}

.ip-info {
  font-size: 24rpx;
  color: #94a3b8;
  margin-bottom: 8rpx;
}

.tip-info {
  font-size: 20rpx;
  color: #cbd5e1;
  text-align: center;
}

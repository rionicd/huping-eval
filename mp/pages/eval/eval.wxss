.eval-container {
  min-height: 100vh;
  background-color: #f4f7fa;
  padding: 24rpx 24rpx 180rpx 24rpx;
  box-sizing: border-box;
}

/* 成功反馈样式 */
.success-view {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  background-color: #ffffff;
  border-radius: 32rpx;
  margin-top: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.03);
}

.success-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1e293b;
  margin-top: 40rpx;
  margin-bottom: 20rpx;
}

.success-desc {
  font-size: 28rpx;
  color: #64748b;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 80rpx;
  padding: 0 40rpx;
}

.success-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.btn-secondary {
  background-color: #f1f5f9;
  color: #475569;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
}

.btn-secondary-hover {
  background-color: #e2e8f0;
}

/* 进度卡片 */
.progress-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.02);
  margin-bottom: 24rpx;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.role-badge {
  background-color: #e0f2fe;
  color: #0369a1;
  font-size: 24rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.progress-text {
  font-size: 26rpx;
  color: #475569;
}

.highlight {
  color: #007aff;
  font-weight: bold;
  font-size: 30rpx;
}

.progress-bar-bg {
  background-color: #f1f5f9;
  height: 12rpx;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.progress-bar-fill {
  background-color: #007aff;
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.progress-tip {
  font-size: 22rpx;
  color: #94a3b8;
}

/* Tab 栏样式 */
.tab-header {
  display: flex;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 10rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.01);
}

.tab-item {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
  padding: 20rpx 0;
  font-size: 26rpx;
  font-weight: 600;
  color: #64748b;
  text-align: center;
  transition: all 0.2s ease;
}

.tab-item.active {
  color: #007aff;
  background-color: #f0f7ff;
  border-radius: 14rpx;
}

.tab-badge {
  position: absolute;
  top: 4rpx;
  right: 12rpx;
  background-color: #ff3b30;
  color: #ffffff;
  font-size: 18rpx;
  min-width: 28rpx;
  height: 28rpx;
  line-height: 28rpx;
  border-radius: 14rpx;
  text-align: center;
  padding: 0 4rpx;
  box-sizing: border-box;
  font-weight: bold;
}

/* 教师列表 */
.teacher-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.teacher-row {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.01);
  transition: all 0.2s ease;
  border-left: 8rpx solid #cbd5e1;
}

.teacher-row.pending {
  border-left-color: #3b82f6; /* 未打分显示淡蓝色左边框 */
}

.teacher-row.completed {
  border-left-color: #10b981; /* 已完成打分显示绿色左边框 */
  background-color: #fafbfc;
}

.teacher-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.teacher-index {
  font-size: 26rpx;
  color: #94a3b8;
  font-weight: bold;
  width: 36rpx;
  text-align: center;
}

.name-box {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.teacher-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #1e293b;
}

.teacher-role-tag {
  font-size: 22rpx;
  color: #94a3b8;
}

/* Picker 样式 */
.score-picker-wrapper {
  margin-left: 20rpx;
}

.score-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-radius: 12rpx;
  height: 68rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  border: 2rpx solid transparent;
  min-width: 140rpx;
  transition: all 0.2s ease;
}

.score-box.no-score {
  background-color: #f1f5f9;
  color: #64748b;
  border-color: #e2e8f0;
}

.score-box.has-score {
  background-color: #e0f2fe;
  color: #0369a1;
  border-color: #bae6fd;
  font-weight: bold;
}

.score-val {
  margin-right: 8rpx;
}

.score-arrow {
  font-size: 18rpx;
  color: inherit;
  opacity: 0.7;
}

.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  color: #94a3b8;
  font-size: 26rpx;
}

/* 底部提交按钮区域 */
.submit-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  padding: 24rpx 30rpx calc(24rpx + env(safe-area-inset-bottom)) 30rpx;
  box-shadow: 0 -8rpx 30rpx rgba(0, 0, 0, 0.04);
  z-index: 100;
}

.btn-submit {
  width: 100% !important;
}

/**app.wxss**/
page {
  background-color: #f4f7fa;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, sans-serif;
  color: #2c3e50;
  font-size: 28rpx;
  box-sizing: border-box;
}

.container {
  padding: 40rpx 30rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 按钮全局统一样式 */
.btn-primary {
  background-color: #007aff;
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: bold;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 122, 255, 0.15);
  transition: all 0.2s ease;
}

.btn-primary-hover {
  background-color: #0062cc;
  opacity: 0.9;
}
